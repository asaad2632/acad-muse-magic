# Copy to .env and fill in real values locally. Never commit .env.

# --- Database (Neon Postgres) ---
# Must include ?sslmode=require (Neon requires TLS; standard CA-verified
# connection, no rejectUnauthorized override).
DATABASE_URL=

# --- Sessions ---
# >=32-char random string, e.g. `openssl rand -hex 32`
SESSION_SECRET=

# --- AI providers (server-only, never exposed to the client) ---
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# --- File storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=acadarchiv-storage
